# Snyk (https://snyk.io) policy file

# Ignores are only valid for 30 days.
version: v1.25.0

# Configuration globale
language-settings:
  javascript:
    # Ignorer les devDependencies dans la production
    includeDevDeps: false

# Seuils de sévérité
severity-threshold: high

# Exclusions de fichiers
exclude:
  global:
    - node_modules
    - dist
    - build
    - coverage
    - .git

# Ignorer certaines vulnérabilités temporairement
# ignore:
#   SNYK-JS-EXAMPLE-123456:
#     - '*':
#       reason: 'False positive ou fix non disponible'
#       expires: '2025-12-31T00:00:00.000Z'
