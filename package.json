{
  "type": "module",
  "dependencies": {
    "@nestjs/mapped-types": "*"
  },
  "name": "solidhive",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:backend": "cd server && npm run lint -- --fix --max-warnings=0",
    "lint:frontend": "cd client && npm run lint -- --fix --max-warnings=0",
    "lint:staged:server": "cd server && eslint src --fix --max-warnings=0",
    "lint:staged:client": "cd client && eslint src --fix --max-warnings=0",
    "format:backend": "prettier --write \"server/src/**/*.ts\"",
    "format:frontend": "prettier --write \"client/src/**/*.{ts,vue}\"",
    "format:check:backend": "prettier --check \"server/src/**/*.ts\"",
    "format:check:frontend": "prettier --check \"client/src/**/*.{ts,vue}\"",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "format": "npm run format:backend && npm run format:frontend",
    "format:check": "npm run format:check:backend && npm run format:check:frontend"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^16.2.6",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "typescript-eslint": "^8.46.2"
  },
  "lint-staged": {
    "server/src/**/*.ts": [
      "npm run lint:staged:server",
      "prettier --write"
    ],
    "client/src/**/*.{ts,vue}": [
      "npm run lint:staged:client",
      "prettier --write"
    ]
  }
}
